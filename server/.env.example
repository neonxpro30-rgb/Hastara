# ===========================
# Hastara .env Configuration
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control!
# ===========================

# PayU Payment Gateway
PAYU_MERCHANT_KEY=your_payu_merchant_key
PAYU_SALT=your_payu_salt

# NimbusPost
NIMBUSPOST_API_KEY=your_nimbuspost_api_key
NIMBUSPOST_SECRET=your_nimbuspost_api_secret
PICKUP_PINCODE=110001

# Firebase Admin (Service Account JSON as a single-line string OR use serviceAccountKey.json file)
FIREBASE_PROJECT_ID=your_firebase_project_id

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Admin Panel Password (change this to something strong!)
ADMIN_PASSWORD=hastara_admin_2024

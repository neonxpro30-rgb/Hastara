# PayU Payment Gateway Credentials
# Replace these with your actual PayU credentials

# For Test Mode (Sandbox)
PAYU_MERCHANT_KEY=your_test_merchant_key
PAYU_SALT=your_test_salt

# For Live Mode (Production)
# PAYU_MERCHANT_KEY=your_live_merchant_key
# PAYU_SALT=your_live_salt

# Important:
# 1. Never commit .env file to version control
# 2. For test mode, get credentials from https://developer.payumoney.com
# 3. For live mode, get credentials from your PayU merchant dashboard
